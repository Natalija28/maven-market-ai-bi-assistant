table Products
	lineageTag: 85f6523c-dc4a-4558-8259-c24a7a451bc3

	measure 'Unique Products' = DISTINCTCOUNT(Products[product_name])
		formatString: #,0
		lineageTag: c8f42472-90bf-4970-bcd8-5240c34803f8

	column product_id
