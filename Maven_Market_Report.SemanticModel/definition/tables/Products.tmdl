	column product_cost
		dataType: double
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 86908338-63c9-4aa5-84c0-778c9a3140f5
		summarizeBy: sum
		sourceColumn: product_cost

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	column product_weight
		dataType: double
		lineageTag: a0cdf790-2494-4495-8334-ed07c5f63c91
		summarizeBy: sum
		sourceColumn: product_weight

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column recyclable
		dataType: double
		lineageTag: 8918bdd7-a11f-4069-aecf-01b5c010ebfe
		summarizeBy: sum
