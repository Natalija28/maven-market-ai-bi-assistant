	column low_fat
		dataType: double
		lineageTag: 67804a2c-a63f-4197-aaec-6a9e74e79bff
		summarizeBy: sum
		sourceColumn: low_fat

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column discount_price
		dataType: double
		formatString: "£"#,0.###############;-"£"#,0.###############;"£"#,0.###############
		lineageTag: 3c0ffac3-9c12-4671-94e8-db270acc8807
		summarizeBy: sum
		sourceColumn: discount_price

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"en-GB"}

	column Round
		dataType: double
		formatString: "£"#,0.###############;-"£"#,0.###############;"£"#,0.###############
		lineageTag: 1199bf6e-f48e-4e85-bd41-4c74db7071ca
		summarizeBy: sum
		sourceColumn: Round

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"en-GB"}

	column Price_Tier =
			SWITCH(
			    TRUE(),
			    Products[product_retail_price]>3, "High",
			    Products[product_retail_price]>1, "Mid",
			    "Low")
		lineageTag: 66280fe7-3620-4966-a421-32957a9588a4
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition Products = m
		mode: import
		source =
				let
				    Source = Csv.Document(File.Contents("C:\AI-PowerBI-Lab_NS\Projects\Maven Market\MavenMarket_Products.csv"),[Delimiter=",", Columns=9, Encoding=1252, QuoteStyle=QuoteStyle.None]),
				    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
