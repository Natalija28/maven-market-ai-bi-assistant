				    #"Changed Type1" = Table.TransformColumnTypes(#"Added Custom",{{"discount_price", Currency.Type}}),
				    #"Inserted Rounding" = Table.AddColumn(#"Changed Type1", "Round", each Number.Round([discount_price], 2), Currency.Type),
				    #"Replaced Value" = Table.ReplaceValue(#"Inserted Rounding",null,0,Replacer.ReplaceValue,{"low_fat"}),
				    #"Replaced Value1" = Table.ReplaceValue(#"Replaced Value",null,0,Replacer.ReplaceValue,{"recyclable"}),
				    #"Changed Type2" = Table.TransformColumnTypes(#"Replaced Value1",{{"product_id", type text}, {"discount_price", type number}, {"Round", type number}})
				in
